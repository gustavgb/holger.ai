{
  "identifier": "default",
  "description": "Default capability for clippy.ai",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-message",
    "core:webview:allow-set-webview-zoom",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" },
        { "path": "$HOME/*/**/.clippy.json" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" },
        { "path": "$HOME/*/**/.clippy.json" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" },
        { "path": "$HOME/*/**/.clippy.json" }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" },
        { "path": "$HOME/*/**/.clippy.json" }
      ]
    },
    "fs:allow-unwatch",
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" },
        { "path": "$HOME/*/**/.clippy.json" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" }
      ]
    },
    "fs:default",
    "fs:scope-config-recursive",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/.config/clippy.ai/**" },
        { "path": "$HOME/[!.]*" },
        { "path": "$HOME/[!.]*/**" }
      ]
    }
  ]
}
